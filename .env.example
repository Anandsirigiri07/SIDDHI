# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# The backend refuses to start if this is missing, shorter than 12 characters,
# or a known placeholder value.
JWT_SECRET_KEY=
GEMINI_API_KEY=your_gemini_api_key_here
DATABASE_URL=sqlite:///./siddhi.db

# Demo users are NOT seeded by default. Opt in for local development only:
# SEED_DEMO_USERS=true
# DEMO_USER_PASSWORD=choose-a-strong-password
